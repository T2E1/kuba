{
  "compilerOptions": {
    "baseUrl": ".",
    "experimentalDecorators": true,
    "target": "ES2019",
    "paths": {
      "@behavior/*": ["packages/behavior/*"],
      "@component/*": ["packages/component/*"],
      "@data/*": ["packages/data/*"],
      "@form/*": ["packages/form/*"],
      "@layout/*": ["packages/layout/*"],
      "@cookie/*": ["packages/cookie/*"],
      "@http": ["packages/http/index.js"],
      "@directive/*": ["packages/directive/*"],
      "@dom/*": ["packages/dom/*"],
      "@echo/*": ["packages/echo/*"],
      "@event/*": ["packages/event/*"],
      "@middleware/*": ["packages/middleware/*"],
      "@mixin/*": ["packages/mixin/*"],
      "@pixel/*": ["packages/pixel/*"],
      "@polyfill/*": ["packages/polyfill/*"],
      "@renderer/*": ["packages/renderer/*"],
      "@result/*": ["packages/result/*"],
      "@router/*": ["packages/router/*"],
      "@spark/*": ["packages/spark/*"],
      "@typography/*": ["packages/typography/*"]
    }
  }
}
