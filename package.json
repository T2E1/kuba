{
  "name": "@t2e1/kuba",
  "version": "0.1.0-alpha.10",
  "description": "Lightweight Web Components primitives and custom elements",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Cleber de M. Goncalves",
    "email": "cleber.demgoncalves@gmail.com",
    "url": "https://github.com/deMGoncalves"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "primitives",
    "declarative",
    "dom",
    "router",
    "reactive"
  ],
  "files": [
    "dist",
    "types.d.ts",
    "packages/**/types.d.ts"
  ],
  "types": "./types.d.ts",
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "default": "./dist/kuba.js"
    },
    "./cookie": "./dist/cookie.js",
    "./http": "./dist/http.js",
    "./directive": "./dist/directive.js",
    "./dom": "./dist/dom.js",
    "./echo": "./dist/echo.js",
    "./event": "./dist/event.js",
    "./middleware": "./dist/middleware.js",
    "./mixin": "./dist/mixin.js",
    "./pixel": "./packages/pixel/index.css",
    "./polyfill": "./dist/polyfill.js",
    "./renderer": "./dist/renderer.js",
    "./result": "./dist/result.js",
    "./router": "./dist/router.js",
    "./spark": "./dist/spark.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/T2E1/kuba.git"
  },
  "bugs": {
    "url": "https://github.com/T2E1/kuba/issues"
  },
  "homepage": "https://github.com/T2E1/kuba#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write .",
    "prepare": "husky",
    "test": "exit 0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@rollup/plugin-terser": "^0.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
