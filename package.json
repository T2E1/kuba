{
  "name": "@t2e1/kuba",
  "version": "0.1.0-alpha.6",
  "description": "Lightweight Web Components primitives and custom elements",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Cleber de M. Goncalves",
    "email": "cleber.demgoncalves@gmail.com",
    "url": "https://github.com/deMGoncalves"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "primitives",
    "declarative",
    "dom",
    "router",
    "reactive"
  ],
  "files": [
    "dist",
    "types",
    "packages/**/types.d.ts"
  ],
  "types": "./types/kuba.d.ts",
  "exports": {
    ".": {
      "types": "./types/kuba.d.ts",
      "default": "./dist/kuba.js"
    },
    "./cookie": {
      "types": "./packages/cookie/types.d.ts",
      "default": "./dist/cookie.js"
    },
    "./http": {
      "types": "./packages/http/types.d.ts",
      "default": "./dist/http.js"
    },
    "./directive": {
      "types": "./packages/directive/types.d.ts",
      "default": "./dist/directive.js"
    },
    "./dom": {
      "types": "./packages/dom/types.d.ts",
      "default": "./dist/dom.js"
    },
    "./echo": {
      "types": "./packages/echo/types.d.ts",
      "default": "./dist/echo.js"
    },
    "./event": {
      "types": "./packages/event/types.d.ts",
      "default": "./dist/event.js"
    },
    "./middleware": {
      "types": "./packages/middleware/types.d.ts",
      "default": "./dist/middleware.js"
    },
    "./mixin": {
      "types": "./packages/mixin/types.d.ts",
      "default": "./dist/mixin.js"
    },
    "./pixel": "./packages/pixel/index.css",
    "./polyfill": {
      "types": "./packages/polyfill/types.d.ts",
      "default": "./dist/polyfill.js"
    },
    "./renderer": {
      "types": "./packages/renderer/types.d.ts",
      "default": "./dist/renderer.js"
    },
    "./result": {
      "types": "./packages/result/types.d.ts",
      "default": "./dist/result.js"
    },
    "./router": {
      "types": "./packages/router/types.d.ts",
      "default": "./dist/router.js"
    },
    "./spark": {
      "types": "./packages/spark/types.d.ts",
      "default": "./dist/spark.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/T2E1/kuba.git"
  },
  "bugs": {
    "url": "https://github.com/T2E1/kuba/issues"
  },
  "homepage": "https://github.com/T2E1/kuba#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write .",
    "prepare": "husky",
    "test": "exit 0",
    "typecheck:types": "tsc -p tsconfig.types.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@rollup/plugin-terser": "^0.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
